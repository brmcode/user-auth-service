# =========================
# DATABASE
# =========================
DB_CONNECTION=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=secret
DB_NAME=auth_db

# =========================
# HTTP
# =========================
HTTP_PORT=8080

# =========================
# GRPC
# =========================
GRPC_PORT=50051

# =========================
# JWT / PASETO
# =========================
TOKEN_TYPE=paseto
SECRET_KEY=12345678910111213141516171819202
TOKEN_DURATION=1h
REFRESH_TOKEN_DURATION=720h

# =========================
# REDIS
# =========================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_TTL=30m

# =========================
# OAUTH - GOOGLE
# =========================
OAUTH_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=xxxxxxxx
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:8080/api/oauth/google/callback
